# Copy to .env and fill in values

# Required in production — set a random 32+ character string
SECRET_KEY=change-me-to-a-random-secret-key

# Flask
FLASK_PORT=8080
FLASK_DEBUG=false

# Data directory for SQLite databases (eol_cache.db and users.db)
# On Railway: set this to your volume mount path, e.g. /data
# Defaults to ./data relative to the project root if not set
DATA_DIR=

# Optional: pre-configure ServiceNow (avoids entering in UI)
# SNOW_URL=https://yourco.service-now.com
# SNOW_USER=api_user
# SNOW_PASSWORD=secret
# SNOW_TABLE=cmdb_ci_netgear

# Cache TTL in hours for live web results (default 24)
CACHE_TTL_HOURS=24
