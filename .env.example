# Copy to .env and fill in values
# Flask
FLASK_PORT=8080
FLASK_DEBUG=false

# Optional: pre-configure ServiceNow (avoids entering in UI)
# SNOW_URL=https://yourco.service-now.com
# SNOW_USER=api_user
# SNOW_PASSWORD=secret
# SNOW_TABLE=cmdb_ci_netgear

# Cache TTL in hours for live web results (default 24)
CACHE_TTL_HOURS=24
